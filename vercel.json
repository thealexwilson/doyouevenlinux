{
  "builds": [
    { 
      "src": "api/main.py", 
      "use": "@vercel/python",
      "config": { 
        "installCommand": "pip install -r requirements.txt",
        "runtime": "python3.11"
      } 
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/main.py" }
  ],
  "crons": [
    {
      "path": "/api/update_protondb_cache",
      "schedule": "0 10 * * *"
    }
  ]
}