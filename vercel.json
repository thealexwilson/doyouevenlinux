{
  "builds": [
    { "src": "api/main.py", "use": "@vercel/python", "config": { "installCommand": "pip install -r requirements.txt" } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/main.py" }
  ],
  "crons": [
    {
      "path": "/api/update_protondb_cache",
      "schedule": "0 10 * * *"
    }
  ]
}